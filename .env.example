# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# App Config
DB_PATH=~/.inkpilot/inkpilot.db
LOG_LEVEL=info

# TwitterAPI.io (reply enrichment — npm run reply:analyze)
TWITTERAPI_IO_KEY=
# Max enrichment requests/second (default 10, conservative). Raise if your balance allows higher QPS.
TWITTERAPI_IO_QPS=10
